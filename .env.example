# MimmoBook environment variables (example)
#
# Copy this file to `.env` for local development, or configure these
# values as repository secrets (Settings -> Secrets and variables ->
# Actions) for CI. The real `.env` is auto-managed by Lovable Cloud
# and must NEVER be committed or edited by hand.
#
# All values below are PUBLIC (publishable) keys and safe to share.
# They are the same values the deployed frontend ships with. Never
# put the SUPABASE_SERVICE_ROLE_KEY in this file or in the repo;
# that secret belongs only in Edge Function secrets and in the CI
# `SUPABASE_SERVICE_ROLE_KEY` GitHub Actions secret.

# -----------------------------------------------------------------
# Backend (Lovable Cloud / Supabase) - publishable values
# -----------------------------------------------------------------

# Public REST/Realtime URL of the project's backend.
# Used by the Vite frontend AND by Deno edge-function tests.
SUPABASE_URL=https://lsgznskkxadplwnxplhd.supabase.co
VITE_SUPABASE_URL=https://lsgznskkxadplwnxplhd.supabase.co

# Anon / publishable JWT. Safe to expose to browsers (RLS enforces
# all access). Required by the supabase-js client and by the Deno
# edge-function tests. Copy the real value from your project's .env
# (Lovable Cloud writes it there automatically).
SUPABASE_ANON_KEY=your-publishable-anon-jwt-here
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-jwt-here

# Project ref (used by some scripts and CI checks).
VITE_SUPABASE_PROJECT_ID=lsgznskkxadplwnxplhd

# -----------------------------------------------------------------
# CI-only (GitHub Actions repository secrets)
# -----------------------------------------------------------------
# Do NOT add these to a local `.env`. They are documented here only
# so contributors know what `npm run test:ci` expects to find.
#
# SUPABASE_SERVICE_ROLE_KEY=<set as a GitHub Actions repository secret>
