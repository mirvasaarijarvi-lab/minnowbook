# Pinned Bun release used by .github/actions/setup-bun-with-diagnostics.
#
# Why pin?
#   - Reproducibility: every CI run installs the same bytes, so a green
#     run today stays green tomorrow regardless of upstream changes.
#   - Supply-chain integrity: the SHA-256 below is verified after
#     install. A tampered or corrupted download fails the job loudly
#     instead of silently executing unknown bytes.
#
# How to bump:
#   1. Pick a new release: https://github.com/oven-sh/bun/releases
#   2. Fetch its SHASUMS256.txt:
#        curl -sSL https://github.com/oven-sh/bun/releases/download/bun-v<VERSION>/SHASUMS256.txt
#   3. Update BUN_VERSION and the per-platform SHA-256 values below.
#   4. Open a PR; CI re-verifies the checksums on every run.
#
# Source of truth for checksums (oven-sh signs the SHASUMS256.txt file
# itself for >=1.1; we verify the archive hash against this file).
BUN_VERSION=1.3.14

# SHA-256 of bun-<platform>.zip from the official GitHub release.
BUN_SHA256_LINUX_X64=951ee2aee855f08595aeec6225226a298d3fea83a3dcd6465c09cbccdf7e848f
BUN_SHA256_LINUX_AARCH64=a27ffb63a8310375836e0d6f668ae17fa8d8d18b88c37c821c65331973a19a3b
BUN_SHA256_DARWIN_X64=4183df3374623e5bab315c547cfa0974533cd457d86b73b639f7a87974cd6633
BUN_SHA256_DARWIN_AARCH64=d8b96221828ad6f97ac7ac0ab7e95872341af763001e8803e8267652c2652620
